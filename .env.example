# Anthropic API Key
# Hol dir deinen Key unter: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Admin Panel Passwort (einfacher Schutz für MVP)
ADMIN_PASSWORD=dein-admin-passwort

# Vercel KV (optional – ohne KV laufen Fallback-Beispiele aus examples.json)
# Erhältlich im Vercel Dashboard unter Storage → KV
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# Optional: Next.js public URL (für Vercel automatisch gesetzt)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
